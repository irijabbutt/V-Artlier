# GEMINI_API_KEY: Required for Gemini AI API calls (server-side only, never
# exposed to the client bundle).
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
# In GitHub Actions, map the GEMINI_API_KEY repository secret to this name.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Firebase Admin (server-side, used by server.ts) ---
# Map from the FB_PROJECTID repository secret.
FB_PROJECTID="MY_FIREBASE_PROJECT_ID"
# Optional — only needed if you're using a named Firestore database.
FB_FIRESTOREDATABASEID=""

# --- Firebase Web/Client config (used by src/firebase.ts, bundled at build time) ---
# These MUST be prefixed with VITE_ for Vite to expose them to client code.
# In your GitHub Actions build step, map each FB_* repository secret to the
# matching VITE_FB_* build-time env var, e.g.:
#   env:
#     VITE_FB_APIKEY: ${{ secrets.FB_APIKEY }}
#     VITE_FB_APPID: ${{ secrets.FB_APPID }}
#     VITE_FB_AUTHDOMAIN: ${{ secrets.FB_AUTHDOMAIN }}
#     VITE_FB_MSGSENDERID: ${{ secrets.FB_MSGSENDERID }}
#     VITE_FB_PROJECTID: ${{ secrets.FB_PROJECTID }}
#     VITE_FB_STORAGEBUCKET: ${{ secrets.FB_STORAGEBUCKET }}
VITE_FB_APIKEY="MY_FIREBASE_API_KEY"
VITE_FB_APPID="MY_FIREBASE_APP_ID"
VITE_FB_AUTHDOMAIN="MY_PROJECT.firebaseapp.com"
VITE_FB_MSGSENDERID="MY_SENDER_ID"
VITE_FB_PROJECTID="MY_FIREBASE_PROJECT_ID"
VITE_FB_STORAGEBUCKET="MY_PROJECT.appspot.com"
VITE_FB_FIRESTOREDATABASEID=""
